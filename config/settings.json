// Zed settings — managed by ~/zed-config repo
//
// Docs: https://zed.dev/docs/configuring-zed
// `zed: open default settings` shows every default.
{
  "edit_predictions": {
    "provider": "zed"
  },
  "cli_default_open_behavior": "existing_window",
  "agent_buffer_font_size": 15.0,
  "agent_ui_font_size": 19.0,
  "project_panel": {
    "dock": "left",
    "default_width": 260
  },
  "outline_panel": {
    "dock": "left",
    "default_width": 260
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "default_width": 420,
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left",
    "default_width": 320
  },
  "debugger": {
    "dock": "left"
  },
  "session": {
    "trust_all_worktrees": true
  },
  "redact_private_values": true,

  // --- vim / neovim parity ---
  "vim_mode": true,
  "base_keymap": "JetBrains",
  "relative_line_numbers": "enabled",
  "scroll_beyond_last_line": "one_page",
  "cursor_blink": false,
  "vim": {
    "use_system_clipboard": "always",
    "use_multiline_find": true,
    "use_smartcase_find": true,
    "highlight_on_yank_duration": 200
  },

  // --- appearance ---
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },

  // nvim-style yank flash: vivid amber, unmistakable on One Dark/Light.
  "theme_overrides": {
    "vim.yank.background": "#ffcc00aa"
  }
}
