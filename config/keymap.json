// Zed keymap — managed by ~/zed-config repo. Leader = <space>.
//
// Model is documented in docs/zed-1.2.5-keymap-guide.md. Summary:
//  - Context tree: Workspace(root) > Pane/Panel(=Dock) > Editor.
//  - More specific (deeper) context wins; file order only breaks ties at
//    the SAME level. So a CLOSE bind in `Dock` automatically beats an
//    OPEN bind in `Workspace` when a panel is focused.
//  - Documented panel contexts in 1.2.5: ProjectPanel, Terminal, Dock.
//    (NO GitPanel/AgentPanel — git & agent are reached via `Dock`.)
//  - No single action both toggles a panel AND focuses it, so each
//    toggle key is bound twice: open+focus (Editor/Workspace) and
//    close (Dock / ProjectPanel).
[
  // == OPEN / focus — editor focused (vim) ============================
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "space space": "file_finder::Toggle",
      "space f f": "file_finder::Toggle",
      "space f r": "file_finder::Toggle",
      "space f p": "projects::OpenRecent",
      "space ;": "command_palette::Toggle",
      "space s s": "outline::Toggle",
      "space s S": "project_symbols::Toggle",
      "space ,": "tab_switcher::Toggle",
      "space u t": "theme_selector::Toggle",

      "space e": "project_panel::ToggleFocus",

      "space /": "buffer_search::Deploy",
      "space s g": "project_search::ToggleFocus",
      "space x x": "diagnostics::Deploy",

      "space b d": "pane::CloseActiveItem",
      "space b o": "pane::CloseInactiveItems",
      "space q": "pane::CloseActiveItem",
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c f": "editor::Format",

      "ctrl-h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-j": ["workspace::ActivatePaneInDirection", "Down"],
      "ctrl-k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-l": ["workspace::ActivatePaneInDirection", "Right"],

      "space g g": "git_panel::ToggleFocus",
      "space g B": "branches::OpenRecent",
      "space g b": "editor::ToggleGitBlame",
      "space g d": "editor::ToggleHunkDiff",
      "] h": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",

      "space d b": "editor::ToggleBreakpoint",
      "space d c": "debugger::Continue",
      "space d s": "debugger::Start",
      "space d o": "debugger::StepOver",
      "space d i": "debugger::StepInto",
      "space d O": "debugger::StepOut",
      "space d p": "debugger::Pause",
      "space d t": "debugger::Stop",
      "space d r": "debugger::RerunSession",

      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem"
    }
  },

  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "shift-left": "editor::Outdent",
      "shift-right": "editor::Indent"
    }
  },

  // == OPEN / focus — no editor (empty pane); also feeds tooltips =====
  // `!Editor` keeps the space-leader out of search/branch/rename boxes.
  {
    "context": "Workspace && !Editor",
    "bindings": {
      "space e": "project_panel::ToggleFocus",
      "space g g": "git_panel::ToggleFocus"
    }
  },

  // == Global: agent open, terminal toggle, dock resize, debug F-keys =
  {
    "context": "Workspace",
    "bindings": {
      "alt-l": "agent::ToggleFocus",
      "cmd-l": "agent::ToggleFocus",
      "ctrl-/": "terminal_panel::Toggle",
      "ctrl-_": "terminal_panel::Toggle",
      "ctrl-`": "terminal_panel::Toggle",
      "cmd-/": "terminal_panel::Toggle",
      "cmd-`": "terminal_panel::Toggle",

      // resize the focused (active) dock — {px:0} arg is REQUIRED.
      "ctrl-alt-right": ["workspace::IncreaseActiveDockSize", { "px": 0 }],
      "ctrl-alt-up": ["workspace::IncreaseActiveDockSize", { "px": 0 }],
      "ctrl-alt-left": ["workspace::DecreaseActiveDockSize", { "px": 0 }],
      "ctrl-alt-down": ["workspace::DecreaseActiveDockSize", { "px": 0 }],
      "ctrl-alt-0": "workspace::ResetActiveDockSize",
      "space w =": "workspace::ResetActiveDockSize",

      "f5": "debugger::Continue",
      "ctrl-f5": "debugger::Start",
      "shift-f5": "debugger::Stop",
      "f9": "editor::ToggleBreakpoint",
      "f10": "debugger::StepOver",
      "f11": "debugger::StepInto",
      "shift-f11": "debugger::StepOut"
    }
  },

  // == CLOSE — project tree (its own context beats generic Dock) ======
  // `not_editing` so `q`/`space e` don't fire while renaming a file.
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "space e": "workspace::ToggleLeftDock",
      "q": "workspace::ToggleLeftDock",
      "ctrl-h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-j": ["workspace::ActivatePaneInDirection", "Down"],
      "ctrl-k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-l": ["workspace::ActivatePaneInDirection", "Right"]
    }
  },

  // == CLOSE — any focused panel/dock (git, agent, terminal, …) =======
  // `Dock` is deeper than `Workspace`, so these win over the open binds
  // above whenever a panel has focus. Keys are panel-specific, so e.g.
  // `space g g` only matters while the git panel is focused.
  // No bare `q` here: the git commit box is an Editor under the dock and
  // a `Dock`-level `q` would block typing 'q' there.
  {
    "context": "Dock",
    "bindings": {
      "space g g": "workspace::ToggleLeftDock",
      "alt-l": "workspace::ToggleRightDock",
      "cmd-l": "workspace::ToggleRightDock",
      "ctrl-/": "terminal_panel::Toggle",
      "ctrl-`": "terminal_panel::Toggle",
      "cmd-/": "terminal_panel::Toggle",
      "cmd-`": "terminal_panel::Toggle",

      "ctrl-h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-j": ["workspace::ActivatePaneInDirection", "Down"],
      "ctrl-k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-l": ["workspace::ActivatePaneInDirection", "Right"]
    }
  }
]
