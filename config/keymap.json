// Zed keymap — managed by ~/zed-config repo. Leader = <space>.
// Model + rationale: docs/zed-1.2.5-keymap-guide.md
//
// VERIFIED against Zed 1.2.5's own default keymap (zed repo, v1.2.5 tag,
// cross-checked against the installed binary's embedded assets):
//  - `workspace::CloseActiveDock` closes the FOCUSED dock/panel,
//    side-agnostic. This is the correct close action.
//  - Real panel contexts: ProjectPanel, GitPanel, AgentPanel, Terminal.
//  - Default AgentPanel binds alt-l -> CycleFavoriteModels; our
//    AgentPanel block (user keymap loads last -> wins) overrides it.
//  - Default `GitPanel && ChangesList` binds space -> git::ToggleStaged,
//    so inside a git file row `space g g` is unavailable; `escape`
//    closes the git panel instead.
//
// NO cmd/super bindings — Linux renders cmd as Super (Omarchy-reserved).
// macOS-only keys, if ever needed, go in an `os == macos` block.
[
  // == OPEN / focus — editor focused (vim) ============================
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "space space": "file_finder::Toggle",
      "space f f": "file_finder::Toggle",
      "space f r": "file_finder::Toggle",
      "space f p": "projects::OpenRecent",
      "space ;": "command_palette::Toggle",
      "space s s": "outline::Toggle",
      "space s S": "project_symbols::Toggle",
      "space ,": "tab_switcher::Toggle",
      "space u t": "theme_selector::Toggle",

      "space e": "project_panel::ToggleFocus",

      "space /": "buffer_search::Deploy",
      "space s g": "project_search::ToggleFocus",
      "space x x": "diagnostics::Deploy",

      "space b d": "pane::CloseActiveItem",
      "space b o": "pane::CloseInactiveItems",
      "space q": "pane::CloseActiveItem",
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c f": "editor::Format",

      "ctrl-h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-j": ["workspace::ActivatePaneInDirection", "Down"],
      "ctrl-k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-l": ["workspace::ActivatePaneInDirection", "Right"],

      "space g g": "git_panel::ToggleFocus",
      "space g B": "branches::OpenRecent",
      "space g b": "editor::ToggleGitBlame",
      "space g d": "editor::ToggleHunkDiff",
      "] h": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",

      "space d b": "editor::ToggleBreakpoint",
      "space d c": "debugger::Continue",
      "space d s": "debugger::Start",
      "space d o": "debugger::StepOver",
      "space d i": "debugger::StepInto",
      "space d O": "debugger::StepOut",
      "space d p": "debugger::Pause",
      "space d t": "debugger::Stop",
      "space d r": "debugger::RerunSession",

      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem"
    }
  },

  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "shift-left": "editor::Outdent",
      "shift-right": "editor::Indent"
    }
  },

  // == OPEN / focus — no editor (empty pane); also feeds tooltips =====
  {
    "context": "Workspace && !Editor",
    "bindings": {
      "space e": "project_panel::ToggleFocus",
      "space g g": "git_panel::ToggleFocus"
    }
  },

  // == Global: agent open/close, terminal, dock resize, debug F-keys ==
  // alt-l -> ToggleRightDock: agent is the SOLE right-dock panel, so this
  // one action opens AND closes it — exactly what the agent panel button
  // dispatches. Null the default ctrl-alt-b (its old binding) so the
  // tooltip resolves to alt-l. Null ctrl-shift-g / ctrl-shift-e so the
  // git / project tooltips show our space binds, not Zed defaults.
  {
    "context": "Workspace",
    "bindings": {
      "alt-l": "workspace::ToggleRightDock",
      "ctrl-alt-b": null,
      "ctrl-b": null,
      "ctrl-shift-g": null,
      "ctrl-shift-e": null,
      "ctrl-/": "terminal_panel::Toggle",
      "ctrl-_": "terminal_panel::Toggle",
      "ctrl-`": "terminal_panel::Toggle",

      "ctrl-alt-right": ["workspace::IncreaseActiveDockSize", { "px": 0 }],
      "ctrl-alt-up": ["workspace::IncreaseActiveDockSize", { "px": 0 }],
      "ctrl-alt-left": ["workspace::DecreaseActiveDockSize", { "px": 0 }],
      "ctrl-alt-down": ["workspace::DecreaseActiveDockSize", { "px": 0 }],
      "ctrl-alt-0": "workspace::ResetActiveDockSize",
      "space w =": "workspace::ResetActiveDockSize",

      "f5": "debugger::Continue",
      "ctrl-f5": "debugger::Start",
      "shift-f5": "debugger::Stop",
      "f9": "editor::ToggleBreakpoint",
      "f10": "debugger::StepOver",
      "f11": "debugger::StepInto",
      "shift-f11": "debugger::StepOut"
    }
  },

  // == CLOSE — focused panel closes via workspace::CloseActiveDock ====
  // Same key that opened it (where Zed leaves the key free), plus
  // `escape` as the universal closer.

  // project tree: `not_editing` so keys don't fire while renaming.
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "space e": "workspace::CloseActiveDock",
      "q": "workspace::CloseActiveDock",
      "escape": "workspace::CloseActiveDock",
      "ctrl-h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-j": ["workspace::ActivatePaneInDirection", "Down"],
      "ctrl-k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-l": ["workspace::ActivatePaneInDirection", "Right"]
    }
  },

  // git: close with workspace::ToggleLeftDock — the EXACT action Zed's
  // own git collapse button dispatches (git is left-docked; that is why
  // its tooltip showed ctrl-b). git_panel::ToggleFocus only unfocuses;
  // workspace::CloseActiveDock didn't fire because focus opens in the
  // COMMIT editor, not the changes list.
  //
  // Two blocks:
  //  1. Zed's EXACT 3-term changes-list context — same specificity as
  //     the default `escape: git_panel::ToggleFocus`; ours loads later
  //     so it wins. `q` is free here too.
  //  2. `GitPanel && !CommitEditor` — covers the rest of the panel
  //     (panel root, etc.) WITHOUT the commit text box, so `escape` =
  //     `git::Cancel` and typing in the commit message still work.
  {
    "context": "GitPanel && ChangesList && !GitBranchSelector",
    "bindings": {
      "escape": "workspace::ToggleLeftDock",
      "q": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "GitPanel && !CommitEditor",
    "bindings": {
      "escape": "workspace::ToggleLeftDock",
      "q": "workspace::ToggleLeftDock"
    }
  },

  // agent: the focused element inside the agent panel is its thread /
  // message editor — a DEEPER context than `AgentPanel` (AcpThread,
  // AcpThread > Editor). A bare AgentPanel bind doesn't catch that leaf,
  // which is why close worked only when the agent was NOT focused.
  // Bind alt-l -> ToggleRightDock at EVERY agent context so it closes
  // regardless of where focus sits. Agent is the sole right-dock panel,
  // so ToggleRightDock is a true open/close toggle and matches the
  // panel button's own action (tooltip = alt-l once ctrl-alt-b is null).
  {
    "context": "AgentPanel",
    "bindings": {
      "alt-l": "workspace::ToggleRightDock",
      "escape": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "AgentPanel && acp_thread",
    "bindings": { "alt-l": "workspace::ToggleRightDock" }
  },
  {
    "context": "AcpThread",
    "bindings": { "alt-l": "workspace::ToggleRightDock" }
  },
  {
    "context": "AcpThread > Editor",
    "bindings": { "alt-l": "workspace::ToggleRightDock" }
  },

  // terminal: ctrl-/ already toggles; escape also closes the dock.
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-/": "workspace::CloseActiveDock",
      "ctrl-_": "workspace::CloseActiveDock"
    }
  }
]
