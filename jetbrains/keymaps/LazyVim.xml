<keymap version="1" name="LazyVim Style" parent="$default">
  <action id="ActivateProjectToolWindow">
    <keyboard-shortcut first-keystroke="ctrl e" />
  </action>
  <action id="ActivateTerminalToolWindow">
    <keyboard-shortcut first-keystroke="ctrl slash" />
  </action>
  <action id="ActivateVersionControlToolWindow">
    <keyboard-shortcut first-keystroke="alt 9" />
  </action>
  <action id="CloseContent">
    <keyboard-shortcut first-keystroke="ctrl w" />
  </action>
  <action id="CommentByLineComment">
    <keyboard-shortcut first-keystroke="ctrl slash" />
  </action>
  <action id="EditorEscape">
    <keyboard-shortcut first-keystroke="f13" />
  </action>
  <action id="FindInPath">
    <keyboard-shortcut first-keystroke="shift ctrl f" />
  </action>
  <action id="FindUsages">
    <keyboard-shortcut first-keystroke="alt f7" />
  </action>
  <action id="Git.Branches">
    <keyboard-shortcut first-keystroke="shift ctrl g" />
  </action>
  <action id="GotoDeclaration">
    <keyboard-shortcut first-keystroke="ctrl b" />
  </action>
  <action id="GotoFile">
    <keyboard-shortcut first-keystroke="ctrl p" />
  </action>
  <action id="GotoImplementation">
    <keyboard-shortcut first-keystroke="ctrl alt b" />
  </action>
  <action id="GotoNextError">
    <keyboard-shortcut first-keystroke="f2" />
  </action>
  <action id="GotoPreviousError">
    <keyboard-shortcut first-keystroke="shift f2" />
  </action>
  <action id="GotoTypeDeclaration">
    <keyboard-shortcut first-keystroke="shift ctrl b" />
  </action>
  <action id="HideActiveToolWindow">
    <keyboard-shortcut first-keystroke="shift escape" />
  </action>
  <action id="MoveLineDown">
    <keyboard-shortcut first-keystroke="alt j" />
  </action>
  <action id="MoveLineUp">
    <keyboard-shortcut first-keystroke="alt k" />
  </action>
  <action id="NextSplitter">
    <keyboard-shortcut first-keystroke="ctrl alt right" />
  </action>
  <action id="NextTab">
    <keyboard-shortcut first-keystroke="alt right" />
  </action>
  <action id="PrevSplitter">
    <keyboard-shortcut first-keystroke="ctrl alt left" />
  </action>
  <action id="PreviousTab">
    <keyboard-shortcut first-keystroke="alt left" />
  </action>
  <action id="QuickJavaDoc">
    <keyboard-shortcut first-keystroke="ctrl q" />
  </action>
  <action id="RecentFiles">
    <keyboard-shortcut first-keystroke="shift ctrl e" />
  </action>
  <action id="ReformatCode">
    <keyboard-shortcut first-keystroke="ctrl alt l" />
  </action>
  <action id="RenameElement">
    <keyboard-shortcut first-keystroke="shift f6" />
  </action>
  <action id="ResizeToolWindowDown">
    <keyboard-shortcut first-keystroke="shift ctrl alt down" />
  </action>
  <action id="ResizeToolWindowLeft">
    <keyboard-shortcut first-keystroke="shift ctrl alt left" />
  </action>
  <action id="ResizeToolWindowRight">
    <keyboard-shortcut first-keystroke="shift ctrl alt right" />
  </action>
  <action id="ResizeToolWindowUp">
    <keyboard-shortcut first-keystroke="shift ctrl alt up" />
  </action>
  <action id="ShowErrorDescription">
    <keyboard-shortcut first-keystroke="ctrl f1" />
  </action>
  <action id="ShowIntentionActions">
    <keyboard-shortcut first-keystroke="alt enter" />
  </action>
  <action id="SplitHorizontally">
    <keyboard-shortcut first-keystroke="shift ctrl minus" />
  </action>
  <action id="SplitVertically">
    <keyboard-shortcut first-keystroke="shift ctrl back_slash" />
  </action>
</keymap>